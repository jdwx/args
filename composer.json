{
  "name": "jdwx/args",
  "description": "A simple PHP library for parsing command line arguments.",
  "license": "MIT",
  "autoload": {
    "psr-4": {
      "JDWX\\Args\\": "src/"
    }
  },
  "require": {
    "php": ">=8.3.0",
    "ext-mbstring": "*",
    "jdwx/param": "^1.2.5",
    "jdwx/quote": "^1.0"
  },
  "require-dev": {
    "roave/security-advisories": "dev-latest",
    "jetbrains/phpstorm-attributes": "^1.0",
    "phpunit/phpunit": "^12",
    "phan/phan": "^v6",
    "phpstan/phpstan": "^2.0"
  },
  "scripts": {
    "phan": "PHAN_ALLOW_XDEBUG=1 php -d xdebug.mode=off vendor/bin/phan --no-progress-bar -S --analyze-twice",
    "phpstan": "php -d xdebug.so vendor/bin/phpstan --no-progress",
    "phpunit": "vendor/bin/phpunit tests"
  }
}